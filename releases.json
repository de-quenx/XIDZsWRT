+ variants\n- **S905X4**: Advan AT01, Akari AX810\n- **S922X**: GT-King-Pro\n\n## Rockchip Series\n- **RK3318**: RK3318-BOX\n- **RK3399**: King3399\n            \n## TUNNEL OPTIONS\n- OpenClash\n- OpenClash + Nikki\n- OpenClash + Nikki + Passwall\n- No Tunnel         \n## KERNEL STABLE VERSION\n- Kernel Versi 5.15.x\n- Kernel Versi 6.1.x\n- Kernel Versi 6.6.x\n- Kernel Versi 6.12.x\n"},{"url":"https://api.github.com/repos/de-quenx/XIDZs-WRT/releases/256086329","assets_url":"https://api.github.com/repos/de-quenx/XIDZs-WRT/releases/256086329/assets","upload_url":"https://uploads.github.com/repos/de-quenx/XIDZs-WRT/releases/256086329/assets{?name,label}","html_url":"https://github.com/de-quenx/XIDZs-WRT/releases/tag/openwrt-Official-24.10.3-22102025","id":256086329,"author":{"login":"github-actions[bot]","id":41898282,"node_id":"MDM6Qm90NDE4OTgyODI=","avatar_url":"https://avatars.githubusercontent.com/in/15368?v=4","gravatar_id":"","url":"https://api.github.com/users/github-actions%5Bbot%5D","html_url":"https://github.com/apps/github-actions","followers_url":"https://api.github.com/users/github-actions%5Bbot%5D/followers","following_url":"https://api.github.com/users/github-actions%5Bbot%5D/following{/other_user}","gists_url":"https://api.github.com/users/github-actions%5Bbot%5D/gists{/gist_id}","starred_url":"https://api.github.com/users/github-actions%5Bbot%5D/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/github-actions%5Bbot%5D/subscriptions","organizations_url":"https://api.github.com/users/github-actions%5Bbot%5D/orgs","repos_url":"https://api.github.com/users/github-actions%5Bbot%5D/repos","events_url":"https://api.github.com/users/github-actions%5Bbot%5D/events{/privacy}","received_events_url":"https://api.github.com/users/github-actions%5Bbot%5D/received_events","type":"Bot","user_view_type":"public","site_admin":false},"node_id":"RE_kwDOPcPYQM4PQ5E5","tag_name":"openwrt-Official-24.10.3-22102025","target_commitish":"main","name":"Op